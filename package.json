{
  "name": "dryvre",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:apps": "concurrently -k -n server,web -c cyan,magenta \"npm run dev -w @dryvre/server\" \"npm run dev -w @dryvre/web\"",
    "dev:server": "npm run dev -w @dryvre/server",
    "dev:web": "npm run dev -w @dryvre/web",
    "build": "npm run build -w @dryvre/shared && npm run build -w @dryvre/db && npm run build -w @dryvre/web && npm run build -w @dryvre/server && npm run build -w @dryvre/mcp",
    "typecheck": "tsc -p tsconfig.tools.json && npm run typecheck --workspaces --if-present",
    "test": "vitest run --config vitest.config.ts && npm run test:skill",
    "test:skill": "PYTHONDONTWRITEBYTECODE=1 python3 -m unittest discover -s .agents/skills/hackathon-submission-builder/tests -p 'test_*.py' && node --test .agents/skills/hackathon-submission-builder/tests/test_video_scenario.mjs",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:generate": "npm run db:generate -w @dryvre/db",
    "db:migrate": "npm run db:migrate -w @dryvre/db",
    "start": "npm run start -w @dryvre/server"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/ws": "^8.18.1",
    "@types/node": "^22.17.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.32.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4",
    "ws": "^8.18.3"
  },
  "engines": { "node": ">=22" }
}
