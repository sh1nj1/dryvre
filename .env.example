NODE_ENV=development
HOST=0.0.0.0
PORT=50000
DATABASE_URL=postgres://dryvre:dryvre@localhost:5432/dryvre
SESSION_SECRET=replace-with-at-least-32-random-characters
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
CODEX_COMMAND=codex
DRYVRE_AGENT_WORKSPACES={"dryvre":"/absolute/path/to/dryvre"}
DRYVRE_AGENT_DATA_DIR=.dryvre-data/agent-runtime
DRYVRE_AGENT_TIMEOUT_MS=900000
DRYVRE_AGENT_FAKE=false
DRYVRE_AGENT_MCP_URL=http://127.0.0.1:50000
